# ==========================================
# LodgeOps Backend Environment Variables
# ==========================================

# Database Configuration
# For local SQLite, use the format: sqlite:///./lodge_manager.db
DATABASE_URL=sqlite:///./lodge_manager.db

# Security & JWT Token Generation
# Generate secure keys using: openssl rand -hex 32
SECRET_KEY=your_super_secret_access_key_here
REFRESH_SECRET_KEY=your_super_secret_refresh_key_here

# Token Expiration Settings (Optional - defaults are shown)
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=7
